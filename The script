-- Scan scripts folder
local function getScriptsFolder()
    local d = workspace:FindFirstChild("delta")
    if d then
        local s = d:FindFirstChild("Scripts")
        if s then return s end
    end
    d = LocalPlayer:FindFirstChild("delta")
    if d then
        local s = d:FindFirstChild("Scripts")
        if s then return s end
    end
    return nil
end

local function refreshScriptsList(filterText)
    for _, c in ipairs(ScriptsList:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
            c:Destroy()
        end
    end
    filterText = (filterText or ""):lower()

    local folder = getScriptsFolder()
    if not folder then
        local hint = Instance.new("TextLabel", ScriptsList)
        hint.Text            = "Create a folder:\nworkspace > delta > Scripts\nand place scripts inside."
        hint.TextSize        = 10
        hint.Font            = Enum.Font.Gotham
        hint.TextColor3      = THEME.TEXT_DIM
        hint.BackgroundTransparency = 1
        hint.Size            = UDim2.new(1, -8, 0, 60)
        hint.TextWrapped     = true
        hint.TextXAlignment  = Enum.TextXAlignment.Center
        return
    end

    local count = 0
    for _, obj in ipairs(folder:GetChildren()) do
        local isScript = obj:IsA("Script") or obj:IsA("LocalScript")
            or obj:IsA("ModuleScript") or obj:IsA("StringValue")
        if isScript then
            local name = obj.Name
            local ext  = name:match("%.(%a+)$") or "lua"
            local skipExt = (activeFilter == "TXT" and ext ~= "txt")
                or (activeFilter == "LUA" and ext ~= "lua" and ext ~= "luau")
            local skipText = filterText ~= "" and not name:lower():find(filterText, 1, true)
            if not skipExt and not skipText then
