local isIconMode = false

local function enterIconMode()
    if isIconMode then return end
    isIconMode = true
    -- Place icon at the nearest edge position
    local vp  = workspace.CurrentCamera.ViewportSize
    local wx  = Window.AbsolutePosition.X + Window.AbsoluteSize.X / 2
    local wy  = Window.AbsolutePosition.Y + Window.AbsoluteSize.Y / 2
    -- Pick closest edge side
    local distLeft   = wx
    local distRight  = vp.X - wx
    local distTop    = wy
    local distBottom = vp.Y - wy
    local minDist    = math.min(distLeft, distRight, distTop, distBottom)

    local iconX, iconY
    if minDist == distLeft then
        iconX = 8
        iconY = math.clamp(wy - ICON_SIZE/2, 8, vp.Y - ICON_SIZE - 8)
    elseif minDist == distRight then
        iconX = vp.X - ICON_SIZE - 8
        iconY = math.clamp(wy - ICON_SIZE/2, 8, vp.Y - ICON_SIZE - 8)
    elseif minDist == distTop then
        iconX = math.clamp(wx - ICON_SIZE/2, 8, vp.X - ICON_SIZE - 8)
        iconY = 8
    else
        iconX = math.clamp(wx - ICON_SIZE/2, 8, vp.X - ICON_SIZE - 8)
        iconY = vp.Y - ICON_SIZE - 8
    end

    IconBtn.Position    = UDim2.new(0, iconX, 0, iconY)
    IconShadow.Position = UDim2.new(0, iconX + ICON_SIZE/2, 0, iconY + ICON_SIZE/2)

    -- Shrink + fade window, show icon
    TweenService:Create(Window, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 1
    }):Play()
    Shadow.Visible = false
    task.delay(0.15, function()
        Window.Visible = false
    end)
    IconBtn.BackgroundTransparency = 1
    IconShadow.BackgroundTransparency = 1
    IconBtn.Visible    = true
    IconShadow.Visible = true
    TweenService:Create(IconBtn,    TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
    TweenService:Create(IconShadow, TweenInfo.new(0.2), {BackgroundTransparency = 0.5}):Play()
end

local function exitIconMode()
    if not isIconMode then return end
    isIconMode = false
    -- Restore window at icon position, centered
    local vp  = workspace.CurrentCamera.ViewportSize
    local ix  = IconBtn.AbsolutePosition.X + ICON_SIZE/2
    local iy  = IconBtn.AbsolutePosition.Y + ICON_SIZE/2
    -- Clamp so window stays fully on screen
    local ww  = Window.AbsoluteSize.X
    local wh  = Window.AbsoluteSize.Y
    local wx  = math.clamp(ix - ww/2, 8, vp.X - ww - 8)
    local wy  = math.clamp(iy - wh/2, 8, vp.Y - wh - 8)
    Window.Position = UDim2.new(0, wx, 0, wy)
    Window.BackgroundTransparency = 1
    Window.Visible = true
    Shadow.Visible = true
    TweenService:Create(Window, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 0}):Play()
    -- Hide icon
    TweenService:Create(IconBtn,    TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
    TweenService:Create(IconShadow, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
    task.delay(0.15, function()
        IconBtn.Visible    = false
        IconShadow.Visible = false
    end)
end

-- Tap icon to restore window
IconBtn.MouseButton1Click:Connect(exitIconMode)

-- Drag icon itself so user can reposition it while collapsed
local iconDragging, iconDragStart, iconDragPos = false, nil, nil
IconBtn.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        iconDragging  = true
        iconDragStart = inp.Position
        iconDragPos   = IconBtn.Position
    end
end)
UIS.InputChanged:Connect(function(inp)
    if not iconDragging then return end
    if inp.UserInputType == Enum.UserInputType.MouseMovement
    or inp.UserInputType == Enum.UserInputType.Touch then
        local d = inp.Position - iconDragStart
        local vp = workspace.CurrentCamera.ViewportSize
        local newX = math.clamp(iconDragPos.X.Offset + d.X, 0, vp.X - ICON_SIZE)
        local newY = math.clamp(iconDragPos.Y.Offset + d.Y, 0, vp.Y - ICON_SIZE)
        IconBtn.Position    = UDim2.new(0, newX, 0, newY)
        IconShadow.Position = UDim2.new(0, newX + ICON_SIZE/2, 0, newY + ICON_SIZE/2)
    end
end)
UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        iconDragging = false
    end
end)

-- ══════════════════════════════════════════════
--  DRAG  (window) + edge-snap check on release
-- ══════════════════════════════════════════════
local dragging, dragStart, dragPos = false, nil, nil
TitleBar.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        dragging  = true
        dragStart = inp.Position
        dragPos   = Window.Position
    end
end)
UIS.InputChanged:Connect(function(inp)
    if not dragging then return end
    if inp.UserInputType == Enum.UserInputType.MouseMovement
    or inp.UserInputType == Enum.UserInputType.Touch then
        local d = inp.Position - dragStart
        Window.Position = UDim2.new(
            dragPos.X.Scale, dragPos.X.Offset + d.X,
            dragPos.Y.Scale, dragPos.Y.Offset + d.Y)
    end
end)
UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            dragging = false
            -- Check if window centre is within EDGE_THRESH of any screen edge
            local vp  = workspace.CurrentCamera.ViewportSize
            local ap  = Window.AbsolutePosition
            local as  = Window.AbsoluteSize
            local cx  = ap.X + as.X / 2
            local cy  = ap.Y + as.Y / 2
            local nearEdge = cx < EDGE_THRESH
                or cx > vp.X - EDGE_THRESH
                or cy < EDGE_THRESH
                or cy > vp.Y - EDGE_THRESH
            if nearEdge then
                enterIconMode()
            end
        end
    end
end)

