local function makeColorRow(label, themeKey)
    local row = Instance.new("Frame", CScroll)
    row.Size             = UDim2.new(1, 0, 0, 38)
    row.BackgroundColor3 = THEME.BG_BTN
    row.BorderSizePixel  = 0
    corner(row, 5)

    -- Label
    local lbl = Instance.new("TextLabel", row)
    lbl.Text             = label
    lbl.TextSize         = 11
    lbl.Font             = Enum.Font.Gotham
    lbl.TextColor3       = THEME.TEXT_PRIMARY
    lbl.BackgroundTransparency = 1
    lbl.Size             = UDim2.new(0, 100, 1, 0)
    lbl.Position         = UDim2.new(0, 8, 0, 0)
    lbl.TextXAlignment   = Enum.TextXAlignment.Left

    -- Color swatch
    local swatch = Instance.new("Frame", row)
    swatch.Size             = UDim2.new(0, 20, 0, 20)
    swatch.Position         = UDim2.new(1, -26, 0.5, -10)
    swatch.BackgroundColor3 = THEME[themeKey] or Color3.new(1,1,1)
    swatch.BorderSizePixel  = 0
    corner(swatch, 4)
    stroke(swatch, THEME.BORDER)

    -- RGB number inputs
    local function numInput(val, xPos)
        local bg = Instance.new("Frame", row)
        bg.Size             = UDim2.new(0, 36, 0, 22)
        bg.Position         = UDim2.new(0, xPos, 0.5, -11)
        bg.BackgroundColor3 = THEME.BG_FILTER
        bg.BorderSizePixel  = 0
        corner(bg, 3)
        stroke(bg, THEME.BORDER)

        local tb = Instance.new("TextBox", bg)
        tb.Text             = tostring(math.floor(val))
        tb.TextSize         = 10
        tb.Font             = Enum.Font.Code
        tb.TextColor3       = THEME.TEXT_PRIMARY
        tb.BackgroundTransparency = 1
        tb.ClearTextOnFocus = false
        tb.Size             = UDim2.new(1, -4, 1, 0)
        tb.Position         = UDim2.new(0, 2, 0, 0)
        tb.TextXAlignment   = Enum.TextXAlignment.Center
        return tb
    end

    local cur = THEME[themeKey] or Color3.new(0.5,0.5,0.5)
    local rTB = numInput(cur.R * 255, 110)
    local gTB = numInput(cur.G * 255, 150)
    local bTB = numInput(cur.B * 255, 190)

    -- Channel labels
    for i, ch in ipairs({"R","G","B"}) do
        local cl = Instance.new("TextLabel", row)
        cl.Text             = ch
        cl.TextSize         = 9
        cl.Font             = Enum.Font.GothamBold
        cl.TextColor3       = THEME.TEXT_DIM
        cl.BackgroundTransparency = 1
        cl.Size             = UDim2.new(0, 10, 0, 20)
        cl.Position         = UDim2.new(0, 100 + (i-1)*40, 0.5, -10)
        cl.TextXAlignment   = Enum.TextXAlignment.Left
    end

    local function applyRGB()
        local r = math.clamp(tonumber(rTB.Text) or 0, 0, 255)
        local g = math.clamp(tonumber(gTB.Text) or 0, 0, 255)
        local b = math.clamp(tonumber(bTB.Text) or 0, 0, 255)
        local col = Color3.fromRGB(r, g, b)
        swatch.BackgroundColor3 = col
        applyThemeKey(themeKey, col)
    end

    rTB.FocusLost:Connect(applyRGB)
    gTB.FocusLost:Connect(applyRGB)
    bTB.FocusLost:Connect(applyRGB)
end

for _, entry in ipairs(colorEntries) do
