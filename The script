local function applyThemeKey(key, color)
    THEME[key] = color
    local targets = colorTargets[key]
    if targets then
        for _, t in ipairs(targets) do
            if t.obj and t.obj.Parent then
                pcall(function() t.obj[t.prop] = color end)
            end
        end
    end
    if key == "CODE" and ScriptBox then
        ScriptBox.TextColor3 = color
    end
    if key == "TEXT_PRIMARY" then
        for _, l in ipairs({STitle, ThTitle, CTitle, TabName}) do
            pcall(function() l.TextColor3 = color end)
        end
    end
end

