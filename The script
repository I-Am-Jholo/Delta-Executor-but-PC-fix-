-- Efficient line number generation
local lineCount = 0
local function rebuildLines(n)
    if n == lineCount then return end
    if n > lineCount then
        for i = lineCount + 1, n do
            local ln = Instance.new("TextLabel", LineNumScroll)
            ln.Name            = "LN" .. i
            ln.Text            = tostring(i)
            ln.TextSize        = 11
            ln.Font            = Enum.Font.Code
            ln.TextColor3      = THEME.TEXT_LINENO
            ln.BackgroundTransparency = 1
            ln.Size            = UDim2.new(1, 0, 0, 17)
            ln.TextXAlignment  = Enum.TextXAlignment.Right
            ln.TextYAlignment  = Enum.TextYAlignment.Center
            ln.BorderSizePixel = 0
        end
    else
        for i = n + 1, lineCount do
            local ln = LineNumScroll:FindFirstChild("LN" .. i)
            if ln then ln:Destroy() end
        end
    end
    lineCount = n
end

