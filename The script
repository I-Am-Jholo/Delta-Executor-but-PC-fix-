--  DELTA EXECUTOR HIDE / SHOW
--  Targets: CoreGui.[hash].Executor  (the real Delta UI)
--  Also hides DarkOverlay, Home, Scripthub,
--  Settings, Sidebar, Console frames.
-- ══════════════════════════════════════════════

-- Names of GUI frames inside the Delta container to hide.
-- The hash/key names randomize every join so we do NOT hardcode them.
-- We scan CoreGui for any container holding an "Executor" GuiObject.
local DELTA_FRAMES = {
    "Executor",
    "DarkOverlay",
    "Home",
    "Scripthub",
    "Settings",
    "Sidebar",
    "Console",
}

local deltaHidden  = false
local savedVisible = {}  -- [frame] = original Visible value

-- Search up to 3 levels deep for a container whose direct child
-- named "Executor" is a GuiObject (not a Folder/Script).
local function getDeltaRoot()
    local CoreGui = game:GetService("CoreGui")

    local function hasExecutorFrame(obj)
        for _, c in ipairs(obj:GetChildren()) do
            if c.Name == "Executor" and (c:IsA("GuiObject") or c:IsA("ScreenGui")) then
                return true
            end
        end
        return false
    end

    for _, child in ipairs(CoreGui:GetChildren()) do
        if hasExecutorFrame(child) then return child end
        for _, sub in ipairs(child:GetChildren()) do
            if hasExecutorFrame(sub) then return sub end
            for _, subsub in ipairs(sub:GetChildren()) do
                if hasExecutorFrame(subsub) then return subsub end
            end
        end
    end
    return nil
end

local function setDeltaVisible(visible)
    local root = getDeltaRoot()
    if not root then
        warn("[Delta Toggle] Delta root not found in CoreGui.")
        return
    end
    for _, frameName in ipairs(DELTA_FRAMES) do
        local frame = root:FindFirstChild(frameName)
        -- Only touch GuiObjects/ScreenGuis - never Folders or Scripts
        if frame and (frame:IsA("GuiObject") or frame:IsA("ScreenGui") or frame:IsA("LayerCollector")) then
            if not visible then
                savedVisible[frame] = frame.Visible
                frame.Visible = false
            else
                frame.Visible = (savedVisible[frame] ~= nil) and savedVisible[frame] or true
            end
        end
    end
end

